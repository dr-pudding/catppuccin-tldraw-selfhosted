{
    "name": "catppuccin-tldraw-selfhosted",
    "description": "tldraw selfhosted with Catppuccin theming and pnpm.",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "packageManager": "pnpm@10.7.0",
    "author": {
        "name": "dr-pudding"
    },
    "license": "MIT",
    "main": "./src/server/server.ts",
    "scripts": {
        "dev": "pnpm dev-node",
        "dev-node": "concurrently -n server,client -c red,blue \"pnpm dev-server-node\" \"pnpm dev-client\"",
        "dev-bun": "concurrently -n server,client -c red,blue \"pnpm dev-server-bun\" \"pnpm dev-client\"",
        "dev-server-node": "tsx watch ./src/server/server.node.ts",
        "dev-server-bun": "bun --watch ./src/server/server.bun.ts",
        "build": "pnpm build:server && pnpm build:client",
        "dev-client": "vite dev --host",
        "build:server": "tsc",
        "build:client": "vite build --app",
        "prod": "NODE_ENV=production node dist/src/server/server.node.js",
        "test": "echo 'No tests yet'"
    },
    "devDependencies": {
        "@types/bun": "^1.1.6",
        "@types/express": "^4.17.21",
        "@types/node": "^22.0.0",
        "@types/react": "^18.3.18",
        "@types/react-dom": "^18.3.5",
        "@types/ws": "^8.18.1",
        "@vitejs/plugin-react-swc": "^3.10.2",
        "concurrently": "^9.1.2",
        "tsx": "^4.19.2",
        "typescript": "^5.8.3",
        "vite": "^7.0.1"
    },
    "dependencies": {
        "@fastify/cors": "^11.0.1",
        "@fastify/static": "^8.2.0",
        "@fastify/websocket": "^11.0.1",
        "@tldraw/assets": "3.15.0",
        "@tldraw/sync": "3.15.0",
        "@tldraw/sync-core": "3.15.0",
        "fastify": "5.4.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-router-dom": "^6.28.2",
        "tldraw": "3.15.0",
        "unfurl.js": "^6.4.0",
        "ws": "^8.18.0"
    }
}
